{
	"name": "hermes",
	"version": "0.1.0",
	"homepage": "https://github.com/k3-cat/hermes",
	"license": "MPL-2.0",
	"author": {
		"name": " k3-cat",
		"email": "k3-cat@outlook.com"
	},
	"type": "module",
	"private": true,
	"scripts": {
		"lint": "oxlint",
		"lint:fix": "oxlint --fix",
		"fmt": "prettier ./src --check",
		"fmt:fix": "prettier --write ./src",
		"dev": "vite",
		"build": "vite build",
		"preview": "pnpm build && vite preview",
		"deploy": "pnpm build && wrangler deploy",
		"deploy:non-production": "pnpm build && wrangler versions upload",
		"cf-typegen": "wrangler types ./types/worker-configuration.d.ts --env-interface CloudflareBindings"
	},
	"dependencies": {
		"hono": "^4.12.12",
		"http-enums": "^1.0.5",
		"jose": "^6.2.2"
	},
	"devDependencies": {
		"@cloudflare/vite-plugin": "^1.32.2",
		"@ianvs/prettier-plugin-sort-imports": "^4.7.1",
		"@types/node": "^25.6.0",
		"oxlint": "^1.60.0",
		"prettier": "^3.8.2",
		"vite": "^8.0.8",
		"vite-ssr-components": "^0.5.2",
		"wrangler": "^4.82.2"
	}
}
